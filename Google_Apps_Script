/**
 * GET Request: Retrieves character data.
 * Triggered by: fetch(`${GAS_URL}?id=YourCharID`)
 */
function doGet(e) {
  try {
    const charId = e.parameter.id;
    if (!charId) throw new Error("No character ID provided.");

    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName("Stats");
    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    
    // Find the row where the first column matches the characterId
    const row = data.find(r => r[0] === charId);
    
    let result = {};
    if (row) {
      headers.forEach((header, index) => {
        result[header] = row[index];
      });
    } else {
      // Return a blank template if character doesn't exist yet
      headers.forEach(header => result[header] = 0);
      result['characterId'] = charId;
    }
    
    return ContentService.createTextOutput(JSON.stringify(result))
      .setMimeType(ContentService.MimeType.JSON);
      
  } catch (err) {
    return ContentService.createTextOutput(JSON.stringify({error: err.message}))
      .setMimeType(ContentService.MimeType.JSON);
  }
}

/**
 * POST Request: Updates or creates character data.
 * Triggered by: fetch(GAS_URL, { method: "POST", body: JSON.stringify(...) })
 */
function doPost(e) {
  try {
    const params = JSON.parse(e.postData.contents);
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName("Stats");
    
    // Refresh data to get latest state
    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    
    const charId = params.id;
    const statName = params.stat;
    const value = params.value;
    
    let rowIndex = data.findIndex(r => r[0] === charId);
    let colIndex = headers.indexOf(statName);
    
    // 1. If the stat column doesn't exist, create a new header
    if (colIndex === -1) {
      colIndex = headers.length;
      sheet.getRange(1, colIndex + 1).setValue(statName);
    }
    
    // 2. If the character row doesn't exist, append a new row
    if (rowIndex === -1) {
      sheet.appendRow([charId]);
      rowIndex = sheet.getLastRow() - 1; 
    }
    
    // 3. Update the specific cell (Spreadsheets are 1-indexed)
    sheet.getRange(rowIndex + 1, colIndex + 1).setValue(value);
    
    return ContentService.createTextOutput("Success").setMimeType(ContentService.MimeType.TEXT);
    
  } catch (err) {
    return ContentService.createTextOutput("Error: " + err.message).setMimeType(ContentService.MimeType.TEXT);
  }
}

/** * ========================================================================
 * MODULE: SECRET ORACLE (GEMINI LLM BRIDGE)
 * ------------------------------------------------------------------------
 * PURPOSE: This function acts as a "Narrative Engine" for the VTT. It 
 * connects the player's terminal to the Gemini 1.5 Flash API to provide 
 * gritty, immersive, and atmospheric descriptions. If you do NOT want to use the LLM, delete this block of code, from this comment to the end of the file, from your Code.gs file.
 * * SETUP:
 * 1. Obtain an API Key from https://aistudio.google.com/
 * 2. Go to Project Settings (Gear Icon) -> Script Properties.
 * 3. Add a property named 'GEMINI_KEY' and paste your key as the value.
 * 4. RE-DEPLOY as a "New Version" to authorize 'UrlFetchApp' permissions.
 * ========================================================================
 */

function askSecretOracle(userPrompt) {
  // CONFIGURATION
  const scriptProps = PropertiesService.getScriptProperties();
  const API_KEY = scriptProps.getProperty('GEMINI_KEY'); 
  const MODEL = "gemini-1.5-flash";
  const URL = `https://generativelanguage.googleapis.com/v1beta/models/${MODEL}:generateContent?key=${API_KEY}`;

  // If key is missing, provide a helpful error in the UI
  if (!API_KEY) {
    return "Void Link Error: GEMINI_KEY not found in Script Properties.";
  }

  const systemInstructions = `
    You are the Secret Oracle for a 'Starforged' TTRPG session. 
    Your goal is to provide gritty, immersive, and brief (2-3 sentences) descriptions. 
    Focus on the themes of the Forge: industrial decay, ancient mystery, and cosmic danger. 
    Be evocative but cryptic. Never mention AI or game mechanics.
    Answer the following player inquiry: 
  `;

  const payload = {
    "contents": [{
      "parts": [{
        "text": systemInstructions + userPrompt
      }]
    }],
    "generationConfig": {
      "temperature": 0.85, // Higher for more "creative" sci-fi flavor
      "maxOutputTokens": 150
    }
  };

  const options = {
    "method": "post",
    "contentType": "application/json",
    "payload": JSON.stringify(payload),
    "muteHttpExceptions": true
  };

  try {
    const response = UrlFetchApp.fetch(URL, options);
    const result = JSON.parse(response.getContentText());
    
    if (result.candidates && result.candidates[0].content) {
      return result.candidates[0].content.parts[0].text;
    } else {
      console.error("API Error Response:", result);
      return "The transmission is garbled. Check your API key or quota.";
    }
  } catch (e) {
    console.error("Fetch Error:", e);
    return "Void Link Failure: " + e.toString();
  }
}
