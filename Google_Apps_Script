/**
 * GET Request: Retrieves character data OR handles Oracle queries.
 */
function doGet(e) {
  try {
    const charId = e.parameter.id;
    
    // ORACLE OVERRIDE: If 'oracle' is in the URL, return LLM response immediately
    if (e.parameter.oracle) {
      const response = askSecretOracle(e.parameter.oracle);
      return ContentService.createTextOutput(response).setMimeType(ContentService.MimeType.TEXT);
    }

    if (!charId) throw new Error("No character ID provided.");

    const ss = SpreadsheetApp.getActiveSpreadsheet();
    let sheet = ss.getSheetByName("Stats");
    
    // Auto-initialize Sheet if missing
    if (!sheet) {
      sheet = ss.insertSheet("Stats");
      sheet.appendRow(["characterId", "health", "momentum", "spirit", "supply", "history", "journal", "assets", "ship_pos"]);
    }

    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    const row = data.find(r => r[0] === charId);
    
    let result = {};
    if (row) {
      headers.forEach((header, index) => { result[header] = row[index]; });
    } else {
      // Create new character row with defaults
      const newRow = [charId, 5, 2, 5, 5, "[]", "", "[]", "0,0"];
      sheet.appendRow(newRow);
      headers.forEach((header, index) => { result[header] = newRow[index] || 0; });
    }
    
    return ContentService.createTextOutput(JSON.stringify(result)).setMimeType(ContentService.MimeType.JSON);
      
  } catch (err) {
    return ContentService.createTextOutput(JSON.stringify({error: err.message})).setMimeType(ContentService.MimeType.JSON);
  }
}

/**
 * POST Request: Updates stats, appends journal entries, or saves assets.
 */
function doPost(e) {
  try {
    const params = JSON.parse(e.postData.contents);
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName("Stats");
    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    const charId = params.id;
    const statName = params.stat;
    const value = params.value;
    
    let rowIndex = data.findIndex(r => r[0] === charId);
    if (rowIndex === -1) {
      sheet.appendRow([charId]);
      rowIndex = sheet.getLastRow() - 1;
    }

    // CASE 1: History Logs (Rolling history of last 50 actions)
    if (statName === "history_entry") {
      return updateHistoryLog(sheet, rowIndex, value);
    }

    // CASE 2: Journal Append (Adds text to end of current journal)
    if (statName === "journal_append") {
      let colIndex = headers.indexOf("journal");
      if (colIndex === -1) {
        colIndex = headers.length;
        sheet.getRange(1, colIndex + 1).setValue("journal");
      }
      const cell = sheet.getRange(rowIndex + 1, colIndex + 1);
      const currentJournal = cell.getValue() || "";
      cell.setValue(currentJournal + value);
      return ContentService.createTextOutput("Journal Updated").setMimeType(ContentService.MimeType.TEXT);
    }
    
    // CASE 3: Standard Update (Stats, Assets, Map Positions)
    let colIndex = headers.indexOf(statName);
    if (colIndex === -1) {
      colIndex = headers.length;
      sheet.getRange(1, colIndex + 1).setValue(statName);
    }
    
    sheet.getRange(rowIndex + 1, colIndex + 1).setValue(value);
    return ContentService.createTextOutput("Success").setMimeType(ContentService.MimeType.TEXT);
    
  } catch (err) {
    return ContentService.createTextOutput("Error: " + err.message).setMimeType(ContentService.MimeType.TEXT);
  }
}

/**
 * Helper to manage the JSON history log string
 */
function updateHistoryLog(sheet, rowIndex, newText) {
  const headers = sheet.getDataRange().getValues()[0];
  let colIndex = headers.indexOf("history");
  if (colIndex === -1) {
    colIndex = headers.length;
    sheet.getRange(1, colIndex + 1).setValue("history");
  }
  const cell = sheet.getRange(rowIndex + 1, colIndex + 1);
  let history = [];
  try { 
    const val = cell.getValue();
    history = val ? JSON.parse(val) : []; 
  } catch(e) { history = []; }
  
  const now = new Date();
  const timestamp = now.getHours().toString().padStart(2, '0') + ":" + now.getMinutes().toString().padStart(2, '0');
  history.push({ time: timestamp, text: newText });
  
  if (history.length > 50) history.shift(); // Keep only last 50 entries
  cell.setValue(JSON.stringify(history));
  return ContentService.createTextOutput("Log Added").setMimeType(ContentService.MimeType.TEXT);
}

/**
 * askSecretOracle: Communicates with Gemini API
 * Targets the Gemini 1.5 Flash model for speed.
 */
function askSecretOracle(userPrompt) {
  const API_KEY = PropertiesService.getScriptProperties().getProperty('GEMINI_KEY'); 
  if (!API_KEY) return "VOID ERROR: NO KEY IN CORES.";

  const MODEL = "gemini-1.5-flash";
  const URL = `https://generativelanguage.googleapis.com/v1/models/${MODEL}:generateContent?key=${API_KEY}`;

  const payload = {
    "contents": [{
      "parts": [{
        "text": "You are a Starforged AI Oracle. Provide a gritty, cryptic, 2-sentence response to: " + userPrompt
      }]
    }],
    "generationConfig": { 
      "temperature": 0.8, 
      "maxOutputTokens": 100 
    }
  };

  try {
    const res = UrlFetchApp.fetch(URL, {
      "method": "post",
      "contentType": "application/json",
      "payload": JSON.stringify(payload),
      "muteHttpExceptions": true 
    });

    const data = JSON.parse(res.getContentText());

    if (res.getResponseCode() === 200) {
      return data.candidates[0].content.parts[0].text;
    } else {
      console.error("Oracle API Error: " + res.getContentText());
      return "VOID LINK ERROR: " + (data.error ? data.error.message : "SIGNAL LOST");
    }
  } catch (e) { 
    return "SIGNAL LOST: SYSTEM CRASH."; 
  }
}

/**
 * Diagnostics: Run this to verify your API key is active.
 */
function checkMyKey() {
  const key = PropertiesService.getScriptProperties().getProperty('GEMINI_KEY');
  if (!key) {
    console.error("❌ NO KEY FOUND in Script Properties.");
  } else {
    const hiddenKey = key.substring(0, 4) + "..." + key.substring(key.length - 4);
    console.log("✅ KEY DETECTED: " + hiddenKey);
  }
}
